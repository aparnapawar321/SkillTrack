{
    "info": {
        "_postman_id": "7d9e8f1a-2b3c-4d5e-6f7g-8h9i0j1k2l3m",
        "name": "SkillTrack Admin API",
        "description": "Postman collection for administrative operations in SkillTrack LMS. Requires a Bearer token with ROLE_ADMIN.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "User Management",
            "item": [
                {
                    "name": "Add Role to User",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"roleName\": \"ROLE_INSTRUCTOR\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/admin/users/1/roles",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "users",
                                "1",
                                "roles"
                            ]
                        },
                        "description": "Adds a specific role to a user. Role is passed in the request body."
                    },
                    "response": []
                },
                {
                    "name": "Remove Role from User",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"roleName\": \"ROLE_INSTRUCTOR\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/admin/users/1/roles",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "users",
                                "1",
                                "roles"
                            ]
                        },
                        "description": "Removes a specific role from a user. Role is passed in the request body."
                    },
                    "response": []
                },
                {
                    "name": "Set User Main Role",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"roleName\": \"ROLE_INSTRUCTOR\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/admin/users/1/main-role",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "users",
                                "1",
                                "main-role"
                            ]
                        },
                        "description": "Specifically switch user between STUDENT and INSTRUCTOR roles. Role is passed in the request body."
                    },
                    "response": []
                },
                {
                    "name": "Get User By ID",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/admin/users/1",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "users",
                                "1"
                            ]
                        },
                        "description": "Retrieves details of any user by ID."
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Course Management",
            "item": [
                {
                    "name": "Restore Course",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/admin/courses/1/restore",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "courses",
                                "1",
                                "restore"
                            ]
                        },
                        "description": "Restores a soft-deleted course."
                    },
                    "response": []
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8080",
            "type": "string"
        },
        {
            "key": "admin_token",
            "value": "your_admin_jwt_here",
            "type": "string"
        }
    ]
}