{
    "info": {
        "name": "SkillTrack API",
        "description": "API collection for SkillTrack Learning Management System",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Current User",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/auth/me",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "me"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Courses",
            "item": [
                {
                    "name": "Get All Courses",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/courses",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "courses"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Course by ID",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/courses/1",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "courses",
                                "1"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Batch Jobs",
            "item": [
                {
                    "name": "Import Courses (Minimal)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": ""
                        },
                        "url": {
                            "raw": "{{base_url}}/api/batch/import-courses",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "batch",
                                "import-courses"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Import Courses (With Parameters)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"filename\": \"courses.csv\",\n  \"batchId\": \"batch-test-001\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/batch/import-courses",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "batch",
                                "import-courses"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Job Status",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/batch/status/1",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "batch",
                                "status",
                                "1"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8080"
        },
        {
            "key": "token",
            "value": "your-jwt-token-here"
        }
    ]
}